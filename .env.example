# ──────────────────────────────────────────────────────────────────────────────
# Texas Permit Tracker — Environment Variables
# Copy this file to .env.local for local development.
# Add all of these to your Vercel project settings before going live.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# ── LemonSqueezy (add these once your account is set up) ─────────────────────
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_VARIANT_ID_STARTER=your-starter-variant-id
LEMONSQUEEZY_VARIANT_ID_PRO=your-pro-variant-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to your Vercel URL in production
